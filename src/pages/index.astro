---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Hero from "@/components/home/Hero.astro";
import AudienceMarquee from "@/components/home/AudienceMarquee.astro";
import HowItWorks from "@/components/home/HowItWorks.astro";
import WhatItDoes from "@/components/home/WhatItDoes.astro";
import DonorManagement from "@/components/home/DonorManagement.astro";
import MarketingSupport from "@/components/home/MarketingSupport.astro";
import Ambassadors from "@/components/home/Ambassadors.astro";
import WhyItWorks from "@/components/home/WhyItWorks.astro";
import FinalCTA from "@/components/home/FinalCTA.astro";
---

<Layout
  title="Xtra Points"
  description="Partner with us and help shape the future of business relationships."
>
  <Header />
  <main>
    <Hero />
    <AudienceMarquee />
    <HowItWorks />
    <WhatItDoes />
    <DonorManagement />
    <MarketingSupport />
    <Ambassadors />
    <WhyItWorks />
    <FinalCTA />
  </main>
  <Footer />
</Layout>
