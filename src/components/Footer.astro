---
import CtaButton from "@/components/CtaButton.astro";
import { brand } from "@/config/brand";

// Jump links to real on-page sections (this is a two-page site — no fake pages).
const explore = [
  { label: "How it works", href: "/#how-it-works" },
  { label: "What it does", href: "/#features" },
  { label: "Donor management", href: "/#donors" },
  { label: "Marketing support", href: "/#marketing" },
  { label: "Student ambassadors", href: "/#ambassadors" },
];

// XtraPoint is a LaCore Payments product — corporate/legal lives on lpt.io.
// (Swap these once XtraPoint has its own terms/privacy pages.)
const LPT = "https://www.lpt.io";
const year = new Date().getFullYear();

const headClass =
  "font-mono text-[0.6875rem] uppercase tracking-[0.12em] text-white/40";
const linkClass =
  "text-sm text-white/70 transition-colors hover:text-lime w-fit";
---

<footer class="relative overflow-hidden bg-ink-bg text-white">
  <div class="dot-grid opacity-60"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 py-16 lg:px-10 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr_1fr]">
      <!-- brand + CTA -->
      <div class="flex flex-col gap-6">
        <img
          src={brand.logo.white}
          alt={brand.name}
          width={brand.logo.width}
          height={brand.logo.height}
          class="h-7 w-auto self-start"
        />
        <p class="max-w-sm text-sm leading-relaxed text-white/65">
          Turn everyday spending into recurring donor revenue — with the
          marketing tools to grow it. {brand.tagline}.
        </p>
        <CtaButton href="/contact" variant="lime" class="!px-5 !py-2.5 !text-sm"
          >Get Started</CtaButton
        >
      </div>

      <!-- explore (section jumps) -->
      <nav class="flex flex-col gap-3" aria-label="Explore">
        <span class={headClass}>Explore</span>
        {explore.map((l) => <a href={l.href} class={linkClass}>{l.label}</a>)}
      </nav>

      <!-- get started / contact -->
      <div class="flex flex-col gap-6">
        <nav class="flex flex-col gap-3" aria-label="Get started">
          <span class={headClass}>Get started</span>
          <a href="/contact" class={linkClass}>Request a walkthrough</a>
          <a href={`mailto:${brand.salesEmail}`} class={linkClass}>
            {brand.salesEmail}
          </a>
        </nav>
        <div class="flex flex-col gap-3">
          <span class={headClass}>Headquarters</span>
          <span class="text-sm leading-relaxed text-white/70">
            900 Wilmeth Rd<br />McKinney, TX 75069
          </span>
        </div>
      </div>
    </div>

    <!-- bottom bar -->
    <div
      class="mt-14 flex flex-col gap-4 border-t border-white/10 pt-8 text-sm text-white/50 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>
        © {year} LaCore Payments Technologies, Inc. ·
        <span class="text-white/40">{brand.name} is a DBA of LaCore Payments Technologies.</span>
      </p>
      <div class="flex items-center gap-6">
        <a href={`${LPT}/terms`} class={linkClass}>Terms</a>
        <a href={`${LPT}/privacy-policy`} class={linkClass}>Privacy</a>
        <a
          href="https://www.linkedin.com/company/lpt-io/"
          class="text-white/60 transition-colors hover:text-lime"
          aria-label="LinkedIn"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3 0-2.96-1.8-2.96-1.8 0-2.08 1.4-2.08 2.86V21h-4z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
