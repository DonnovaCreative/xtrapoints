---
import Eyebrow from "@/components/Eyebrow.astro";
import DonorDashboard from "@/components/islands/DonorDashboard.tsx";

const bullets = [
  {
    title: "Real-time donor activity.",
    body: "Every round-up, recurring gift, and one-time donation lands in one feed.",
  },
  {
    title: "Segments & lifetime value.",
    body: "Know who your top supporters are, what they respond to, and where to focus.",
  },
];
---

<section class="bg-white py-20 lg:py-28">
  <div
    class="mx-auto grid max-w-7xl items-center gap-14 px-6 lg:grid-cols-2 lg:px-10"
  >
    <div class="reveal-left">
      <Eyebrow index="03" label="Donor management" />
      <h2
        class="font-display mt-4 text-[clamp(2.25rem,5vw,3.5rem)] uppercase leading-[0.95] tracking-tight text-gray-900"
      >
        One <span class="ed ed-dark">Unified</span> view of every supporter.
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-gray-600">
        Track every donor, campaign, and transaction inside a single dashboard.
        View historical giving, manage recurring plans, and see exactly which
        initiatives drive lift — without stitching tools together or waiting on
        a quarterly report.
      </p>

      <ul class="mt-8 flex flex-col gap-5">
        {bullets.map((b) => (
          <li class="flex gap-3.5">
            <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-lime-soft text-lime-dark">
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <span>
              <span class="font-semibold text-gray-900">{b.title}</span>{" "}
              <span class="text-gray-600">{b.body}</span>
            </span>
          </li>
        ))}
      </ul>
    </div>

    <div class="reveal-right">
      <DonorDashboard client:visible />
    </div>
  </div>
</section>
