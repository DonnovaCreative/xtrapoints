---
import Eyebrow from "@/components/Eyebrow.astro";
import PlaybookMark from "@/components/PlaybookMark.astro";

const bullets = [
  {
    icon: `<circle cx="12" cy="12" r="9" /><path d="M9 12l2 2 4-4" />`,
    title: "Real, verified growth.",
    body: "App downloads, verified registrations, and recurring donors you can measure — every signup tied back to the ambassador who drove it.",
  },
  {
    icon: `<path d="M8.5 8.5a5 5 0 0 0 0 7M15.5 8.5a5 5 0 0 1 0 7M5.5 5.5a9 9 0 0 0 0 13M18.5 5.5a9 9 0 0 1 0 13" /><circle cx="12" cy="12" r="1.5" fill="currentColor" />`,
    title: "Reach you can’t buy.",
    body: "Taps audiences staff can’t easily access — Greek life, athletic events, alumni gatherings, the spaces where actual influence lives.",
  },
  {
    icon: `<circle cx="8" cy="15" r="4" /><path d="M10.8 12.2L20 3M16 7l3 3" />`,
    title: "Turnkey for you.",
    body: "We provide the platform, toolkit, and coaching; your campus brings the energy. No new hires, no new program to build from scratch.",
  },
];
---

<section class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="reveal max-w-3xl">
      <Eyebrow index="05" label="Student ambassadors" />
      <h2
        class="font-display mt-4 max-w-[18ch] text-[clamp(2.5rem,6vw,4rem)] uppercase leading-[0.92] tracking-[-0.015em] text-gray-900"
      >
        Put your students to <span class="ed ed-dark">Work</span> for your program.
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-gray-600">
        The Ambassador Program is a student-powered growth engine — driving app
        downloads, verified registrations, and recurring donors through channels
        staff outreach can’t reach: Greek life, tailgates, orientation, alumni
        weekends. It’s low-cost, always-on marketing that builds school pride
        today and a pipeline of future alumni donors who give for years after
        they graduate.
      </p>
    </div>

    <div class="mt-14 grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:gap-12">
      <!-- ∞ stat panel -->
      <div
        class="reveal-left relative flex min-h-[360px] flex-col justify-between overflow-hidden rounded-3xl bg-ink p-10 text-white"
      >
        <div class="dot-grid"></div>
        <div
          class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full opacity-40 blur-3xl"
          style="background: radial-gradient(circle, rgba(170,241,10,0.3) 0%, transparent 65%);"
          aria-hidden="true"
        >
        </div>
        <PlaybookMark mark="o" class="bottom-6 right-8 h-20 w-20" rotate={-8} opacity={0.5} />
        <div class="relative">
          <p class="font-mono text-[0.6875rem] font-bold uppercase tracking-[0.12em] text-lime">
            Always-on growth
          </p>
          <p class="font-display -mt-2 text-[clamp(7rem,14vw,11rem)] leading-[0.85] text-lime">
            ∞
          </p>
          <p class="max-w-sm text-[0.9375rem] leading-relaxed text-white/75">
            Recruitment that never sleeps — students reach corners of campus and
            alumni networks your staff simply can’t.
          </p>
        </div>
        <div class="relative mt-8 flex items-center justify-between border-t border-white/10 pt-5">
          <span class="font-mono text-[0.625rem] font-bold uppercase tracking-[0.08em] text-white/50">
            Channels we tap
          </span>
          <span class="text-[0.8125rem] font-semibold text-white">
            Greek · Athletics · Alumni · Events
          </span>
        </div>
      </div>

      <!-- bullets + CTA -->
      <div class="reveal-right flex flex-col justify-between">
        <ul class="stagger flex flex-col gap-4">
          {bullets.map((b) => (
            <li class="flex items-start gap-3.5 rounded-xl border border-gray-200 bg-white px-5 py-4">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-primary-50 text-primary-700">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={b.icon} />
              </span>
              <span>
                <strong class="font-semibold text-gray-900">{b.title}</strong>{" "}
                <span class="text-gray-600">{b.body}</span>
              </span>
            </li>
          ))}
        </ul>
        <a
          href="mailto:sales@xtrapoints.com"
          class="mt-8 inline-flex w-fit items-center gap-2.5 rounded-full bg-lime px-6 py-3.5 text-[0.9375rem] font-bold text-ink transition-all duration-300 hover:bg-lime-deep hover:-translate-y-0.5"
        >
          Learn about the Ambassador Program
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
