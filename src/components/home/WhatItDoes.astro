---
import Eyebrow from "@/components/Eyebrow.astro";

const blocks = [
  {
    iconBg: "bg-primary-500",
    icon: `<path d="M17 2l4 4-4 4" /><path d="M3 11V9a4 4 0 0 1 4-4h14" /><path d="M7 22l-4-4 4-4" /><path d="M21 13v2a4 4 0 0 1-4 4H3" />`,
    title: "Recurring donors you wouldn’t otherwise have.",
    body: "Round-up gives supporters a frictionless way to give every day. Our engine projects each donor’s monthly impact and prompts optional minimums and multipliers — so the average gift grows on its own.",
    tags: ["Forecasting", "Multipliers", "Minimums"],
  },
  {
    iconBg: "bg-primary-900",
    icon: `<rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" />`,
    title: "Revenue you can actually plan around.",
    body: "Choose the rhythm that fits your supporters — weekly, monthly, quarterly, annual — and let the platform handle every renewal in the background. Predictable cycles, healthier forecasts.",
    tags: ["Weekly", "Monthly", "Quarterly", "Annual"],
  },
  {
    iconBg: "bg-success-500",
    icon: `<rect x="5" y="2" width="14" height="20" rx="3" /><path d="M11 18h2" />`,
    title: "A branded experience supporters actually open.",
    body: "Every gift lives inside a dedicated mobile app carrying your colors, marks, and program identity — instant access, transparency into impact, and a reason to come back.",
    tags: ["iOS", "Android", "Your brand"],
  },
];
---

<section id="features" class="relative overflow-hidden bg-ink py-20 lg:py-28">
  <!-- dark photo background + navy tint (same flagged stock photo as §06) -->
  <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
    <img
      src="/images/why-02-stock.jpg"
      alt=""
      loading="lazy"
      class="absolute left-0 top-[-5%] h-[110%] w-full object-cover"
    />
    <div
      class="absolute inset-0"
      style="background:linear-gradient(140deg,rgba(3,17,109,0.92) 0%,rgba(3,17,109,0.82) 45%,rgba(11,14,60,0.95) 100%)"
    >
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-10">
    <div class="reveal max-w-[56rem]">
      <Eyebrow index="02" label="What it does for you" dark />
      <h2
        class="font-display mt-4 max-w-[18ch] text-[clamp(2.5rem,6vw,4rem)] uppercase leading-[0.92] tracking-[-0.015em] text-white"
      >
        Built to <span class="ed">Multiply</span> every gift.
      </h2>
      <p class="mt-5 max-w-[38rem] text-lg leading-relaxed text-white/75">
        Three things working together to turn casual fans into compounding
        supporters — and small change into season-long revenue.
      </p>
    </div>

    <div class="stagger mt-14 grid gap-6 md:grid-cols-3">
      {blocks.map((b) => (
        <article class="flex h-full flex-col rounded-3xl border border-white/12 bg-white p-8 shadow-[0_22px_50px_-18px_rgba(0,0,0,0.45),0_8px_16px_-8px_rgba(0,0,0,0.25)]">
          <div class={`flex h-12 w-12 items-center justify-center rounded-[0.625rem] text-white ${b.iconBg}`}>
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={b.icon} />
          </div>
          <h3 class="mt-6 text-xl font-bold leading-snug tracking-tight text-gray-900">
            {b.title}
          </h3>
          <p class="mt-3 flex-1 leading-relaxed text-gray-600">{b.body}</p>
          <div class="mt-6 flex flex-wrap gap-2">
            {b.tags.map((t) => (
              <span class="inline-flex items-center rounded-full border border-gray-200 bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-700">
                {t}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
