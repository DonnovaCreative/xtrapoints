---
import CtaButton from "@/components/CtaButton.astro";
import StatTrio from "@/components/islands/StatTrio.tsx";
import PhoneMockup from "@/components/home/PhoneMockup.astro";
import PlaybookMark from "@/components/PlaybookMark.astro";
---

<section class="relative overflow-hidden bg-ink">
  <!-- giant outlined wordmark anchored to the bottom edge -->
  <span
    class="backdrop-type bottom-[-7%] left-1/2 -translate-x-1/2"
    style="font-size:clamp(6rem,18vw,16rem);opacity:0.13;"
    aria-hidden="true">XTRAPOINTS</span
  >

  <!-- playbook chalk marks (positioned against the section, like the live page) -->
  <PlaybookMark mark="x" class="top-[6%] right-[7%]" width="clamp(56px,7vw,96px)" rotate={12} delay={0.4} />
  <PlaybookMark mark="o" class="top-[52%] right-[2%] hidden lg:block" width="84px" rotate={-10} delay={1} />
  <PlaybookMark mark="arrow" class="bottom-[19%] left-[42%] hidden lg:block" width="54px" rotate={26} delay={0.7} opacity={0.9} />

  <div
    class="relative z-10 mx-auto grid max-w-7xl gap-10 px-6 pb-20 pt-16 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-12 lg:px-10 lg:pb-28 lg:pt-20"
  >
    <!-- copy -->
    <div>
      <h1
        class="font-display text-[clamp(3rem,7vw,5.5rem)] uppercase leading-[1.02] tracking-tight text-white"
      >
        <span class="block">
          <span class="hero-word" style="animation-delay:0.12s">Every</span>
          <span class="hero-word" style="animation-delay:0.18s">purchase,</span>
          <span class="hero-word" style="animation-delay:0.24s">a</span>
        </span>
        <span
          class="font-editorial my-1 block text-[1.1em] leading-[0.9] text-lime [text-transform:none]"
        >
          <span class="hero-word" style="animation-delay:0.36s">Small</span>
          <span class="hero-word" style="animation-delay:0.44s">Act</span>
          <span class="hero-word" style="animation-delay:0.52s">Of</span>
          <span class="hero-word" style="animation-delay:0.60s">Support</span>
        </span>
        <span class="block">
          <span class="hero-word" style="animation-delay:0.72s">For</span>
          <span class="relative inline-block">
            <span class="hero-word" style="animation-delay:0.78s">Your</span>
            <span class="hero-word" style="animation-delay:0.84s">Team.</span>
            <PlaybookMark
              mark="underline"
              class="-bottom-3 left-0"
              width="100%"
              delay={1.1}
            />
          </span>
        </span>
      </h1>

      <div class="reveal">
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/75">
          Xtra Points helps athletic departments, alumni associations, and
          booster clubs turn everyday spending into recurring donor revenue —
          paired with the marketing tools to grow it. No implementation cost.
          Live in days.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-4">
          <CtaButton href="/contact" variant="lime">Get Started</CtaButton>
          <span class="font-mono text-xs uppercase tracking-[0.04em] text-white/50">
            Zero upfront cost · No long contracts
          </span>
        </div>

        <div class="mt-12 max-w-md">
          <StatTrio client:visible />
        </div>
      </div>
    </div>

    <!-- phone visual -->
    <div class="relative reveal-right">
      <PhoneMockup />
    </div>
  </div>
</section>
