---
import Eyebrow from "@/components/Eyebrow.astro";

// NOTE: both photos below are Pexels stock pulled from the live page.
// Flagged for replacement with owned XtraPoints imagery — see README.
const plays = [
  {
    label: "Play 01",
    stat: "0 → live",
    image: "/images/why-01-stock.jpg",
    title: "Zero upfront cost. Live in days.",
    body: "No setup fees. No long contracts. Done-for-you onboarding gets your program live in hours, not quarters — and lower transaction fees mean more of each donation reaches the team.",
  },
  {
    label: "Play 02",
    stat: "9 yrs",
    image: "/images/why-02-stock.jpg",
    title: "A payments stack we own end-to-end.",
    body: "Backed by nine years of profitable payments operations, 450+ active merchants, and a stack we own outright — gateway, processor, technology. No third-party hand-offs. No surprise shutdowns.",
  },
];
---

<section class="relative overflow-hidden bg-ink py-20 text-white lg:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="max-w-3xl">
      <Eyebrow index="06" label="Why it works" dark />
      <h2
        class="font-display mt-4 text-[clamp(2.25rem,5vw,3.5rem)] uppercase leading-[0.95] tracking-tight text-white"
      >
        More of every dollar.
        <span class="font-editorial block text-[0.5em] text-lime [text-transform:none]">
          Where it belongs.
        </span>
      </h2>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/75">
        Zero upfront cost. No long contracts. Lower transaction fees than
        competing round-up platforms. Every basis point we save flows back to
        your program.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2">
      {plays.map((p) => (
        <article class="flex flex-col overflow-hidden rounded-3xl border border-white/12 bg-white/[0.04] shadow-[0_22px_50px_-18px_rgba(0,0,0,0.45)]">
          <div class="relative h-52 overflow-hidden">
            <img
              src={p.image}
              alt=""
              loading="lazy"
              class="h-full w-full object-cover opacity-80"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/90 to-ink/10"></div>
            <span class="absolute left-5 top-5 inline-flex items-center gap-2 rounded-full bg-black/30 px-3 py-1 font-mono text-[0.625rem] uppercase tracking-[0.08em] text-white/80 backdrop-blur-sm">
              <svg class="h-3 w-3 text-lime" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              / {p.label}
            </span>
            <span class="font-display absolute bottom-4 left-5 text-4xl leading-none text-lime">
              {p.stat}
            </span>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h3 class="text-xl font-bold tracking-tight text-white">{p.title}</h3>
            <p class="mt-3 flex-1 leading-relaxed text-white/70">{p.body}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- trust badges -->
    <div class="mt-12 flex flex-col items-start gap-6 border-t border-white/10 pt-8 sm:flex-row sm:items-center sm:justify-between">
      <span class="font-mono text-xs uppercase tracking-[0.08em] text-white/45">
        Built on enterprise-grade infrastructure
      </span>
      <div class="flex flex-wrap items-center gap-6">
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-full border border-white/30 text-white">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span>
            <span class="block text-sm font-semibold text-white">AICPA SOC 2</span>
            <span class="block font-mono text-[0.625rem] uppercase tracking-[0.06em] text-white/50">Type II compliant</span>
          </span>
        </div>
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-full border border-white/30 text-white">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="4" y="10" width="16" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 10V7a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </span>
          <span>
            <span class="block text-sm font-semibold text-white">PCI DSS</span>
            <span class="block font-mono text-[0.625rem] uppercase tracking-[0.06em] text-white/50">Certified payments</span>
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
