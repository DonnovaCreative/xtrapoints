# Web3Forms access key for the /contact form.
#
# 1. Create a free key at https://web3forms.com using the inbox you want
#    submissions delivered to: sales@xtrapoints.com
# 2. Copy this file to `.env` and paste your key below.
# 3. Restart `npm run dev` (PUBLIC_ vars are read at startup).
#
# The PUBLIC_ prefix is required so Astro exposes it to the client-side form.
PUBLIC_WEB3FORMS_KEY=5ee454dd-c546-4ac6-9a74-ebc581b20440

# hCaptcha on the contact form uses Web3Forms' free built-in hCaptcha — no key
# needed here. You MUST enable hCaptcha in the Web3Forms dashboard for the
# access key above, or the token won't actually be verified.
# Only set this if you later move to a Web3Forms Pro custom hCaptcha sitekey:
# PUBLIC_HCAPTCHA_SITEKEY=
